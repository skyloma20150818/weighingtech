// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Category {
  id     String @id
  name   String
  nameEn String
}

model AlbumCategory {
  id     String @id
  name   String
  nameEn String
}

model SolutionCategory {
  id     String @id
  name   String
  nameEn String
}

model Product {
  id             String            @id
  code           String
  name           String
  nameEn         String?
  category       String
  description    String
  descriptionEn  String?
  image          String
  has360         Boolean?          @default(false)
  images360Count Int?              @default(0)
  manualUrl      String?
  specs          Json?             // Native Json support in Prisma 6+ for SQLite
  introImages    ProductImage[]
  documents      ProductDocument[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductDocument {
  id            String  @id @default(cuid())
  title         String
  titleEn       String?
  description   String?
  descriptionEn String?
  docType       String?
  format        String
  fileSize      String?
  url           String
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// 通用文档（不隶属于具体产品，如企业资质证书、通用手册等）
model Document {
  id            String  @id @default(cuid())
  title         String
  titleEn       String?
  description   String?
  descriptionEn String?
  docType       String?  // 文档类型: 资质证书/产品手册/技术资料/其他
  format        String   // 文件格式: PDF/ZIP/DOC等
  fileSize      String?   // 文件大小
  url           String    // 文件路径
  category      String?   // 分类: certificates/manuals/technical/other
  sort          Int      @default(0)  // 排序
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AlbumItem {
  id       String  @id
  title    String
  titleEn  String?
  category String
  image    String
}

model VideoItem {
  id        String  @id
  title     String
  titleEn   String?
  category  String
  thumbnail String
  videoUrl  String
}

model SiteConfig {
  id       Int      @id @default(1)
  hero     Json?    // { badge, title1, title2, title3, subtitle, videoUrl, poster }
  features Json?    // [ { icon, title, desc, titleEn, descEn } ]
  about    Json?    // { description, intro, factoryLabel, features: [] }
  contact  Json?    // { phone, mobile, email, address }
  consult  Json?    // { title, description, wechat: {}, qq: {} }
  sections Json?    // { products: {}, solutions: {}, customization: {}, album: {} }
}
